{
  "$comment": "Termless backend manifest. Upstream uses URI format: npm:<pkg>, crate:<name>, github:<org/repo>",
  "version": "0.3.0",
  "backends": {
    "xtermjs": {
      "package": "@termless/xtermjs",
      "upstream": "npm:@xterm/headless",
      "upstreamVersion": "5.5.0",
      "type": "js",
      "default": true
    },
    "ghostty": {
      "package": "@termless/ghostty",
      "upstream": "npm:ghostty-web",
      "upstreamVersion": "0.4.0",
      "type": "wasm",
      "default": true
    },
    "vt100": {
      "package": "@termless/vt100",
      "upstream": "npm:@termless/vt100",
      "upstreamVersion": "0.3.0",
      "type": "js",
      "default": true
    },
    "alacritty": {
      "package": "@termless/alacritty",
      "upstream": "crate:alacritty_terminal",
      "upstreamVersion": "0.26.0",
      "type": "native",
      "default": false,
      "requiresBuild": "Rust toolchain (cargo build --release)"
    },
    "wezterm": {
      "package": "@termless/wezterm",
      "upstream": "crate:tattoy-wezterm-term",
      "upstreamVersion": "0.1.0-fork.5",
      "type": "native",
      "default": false,
      "requiresBuild": "Rust toolchain (cargo build --release)"
    },
    "peekaboo": {
      "package": "@termless/peekaboo",
      "upstream": "npm:peekaboo",
      "upstreamVersion": "0.7.0",
      "type": "os",
      "default": false,
      "platforms": ["darwin"]
    },
    "vt100-rust": {
      "package": "@termless/vt100-rust",
      "upstream": "crate:vt100",
      "upstreamVersion": "0.15.0",
      "type": "native",
      "default": false,
      "requiresBuild": "Rust toolchain (cargo build --release)"
    },
    "libvterm": {
      "package": "@termless/libvterm",
      "upstream": "github:neovim/libvterm",
      "upstreamVersion": "0.3.0",
      "type": "wasm",
      "default": false,
      "requiresBuild": "Emscripten SDK (bash build/build.sh)"
    },
    "kitty": {
      "package": "@termless/kitty",
      "upstream": "github:kovidgoyal/kitty",
      "upstreamVersion": "0.40.0",
      "type": "native",
      "default": false,
      "requiresBuild": "C compiler + Python 3 + git (clones kitty GPL source)"
    }
  }
}
