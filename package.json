{
  "name": "@termless/monorepo",
  "version": "0.2.0",
  "description": "Headless terminal library for cross-terminal TUI testing",
  "keywords": [
    "ghostty",
    "headless",
    "terminal",
    "testing",
    "tui",
    "xterm"
  ],
  "homepage": "https://termless.dev/",
  "bugs": {
    "url": "https://github.com/beorn/termless/issues"
  },
  "license": "MIT",
  "author": "Beorn",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/termless.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "module": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./svg": "./src/svg.ts",
    "./png": "./src/png.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "ci": "bun vitest run",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "docs:dev": "vitepress dev docs/site",
    "docs:build": "vitepress build docs/site",
    "docs:preview": "vitepress preview docs/site",
    "cli": "bun packages/cli/src/cli.ts",
    "matrix": "bun packages/cli/src/cli.ts matrix",
    "publish:all": "bun run publish:core && bun run publish:packages",
    "publish:core": "npm publish",
    "publish:packages": "for pkg in packages/xtermjs packages/ghostty packages/vt100 packages/viterm packages/peekaboo packages/cli packages/alacritty packages/wezterm; do (cd $pkg && npm publish); done"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "vitepress": "^1.5.0",
    "vitepress-plugin-llms": "^1.0.0",
    "vitest": "^4.0.0"
  },
  "optionalDependencies": {
    "@resvg/resvg-js": "^2.6.2"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
