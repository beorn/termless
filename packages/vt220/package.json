{
  "name": "@termless/vt220",
  "version": "0.1.1",
  "description": "Pure TypeScript VT220 backend for termless — 8 colors, insert/delete, selective erase",
  "keywords": [
    "ansi-parser",
    "ecma-48",
    "headless",
    "terminal",
    "terminal-emulator",
    "terminal-testing",
    "tui",
    "typescript",
    "vt220",
    "zero-dependency"
  ],
  "homepage": "https://termless.dev/",
  "bugs": {
    "url": "https://github.com/beorn/termless/issues"
  },
  "license": "MIT",
  "author": "Beorn",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/termless.git",
    "directory": "packages/vt220"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "module": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "dependencies": {
    "vt220.js": "^0.1.0"
  },
  "peerDependencies": {
    "@termless/core": "*"
  },
  "tsdown": {
    "clean": true,
    "dts": true,
    "entry": "src/index.ts",
    "format": "esm"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=23.6.0"
  }
}
