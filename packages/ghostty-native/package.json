{
  "name": "@termless/ghostty-native",
  "version": "0.3.1",
  "description": "Native Ghostty backend for termless — libghostty-vt via Zig napigen N-API bindings",
  "keywords": [
    "ghostty",
    "headless",
    "libghostty",
    "native",
    "terminal",
    "terminal-emulator",
    "terminal-testing",
    "tui",
    "vt-parser",
    "zig"
  ],
  "homepage": "https://termless.dev/",
  "bugs": {
    "url": "https://github.com/beorn/termless/issues"
  },
  "license": "MIT",
  "author": "Beorn",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/termless.git",
    "directory": "packages/ghostty-native"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "module": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
