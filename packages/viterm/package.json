{
  "name": "@termless/test",
  "version": "0.3.1",
  "description": "Vitest integration for termless — 25+ terminal matchers, fixtures, and snapshot serializer for TUI testing",
  "keywords": [
    "ansi",
    "jest",
    "matchers",
    "snapshot-testing",
    "terminal",
    "terminal-testing",
    "test-fixtures",
    "testing",
    "tui",
    "tui-testing",
    "vitest"
  ],
  "homepage": "https://termless.dev/",
  "bugs": {
    "url": "https://github.com/beorn/termless/issues"
  },
  "license": "MIT",
  "author": "Beorn",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/termless.git",
    "directory": "packages/viterm"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "module": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./matchers": "./src/matchers.ts",
    "./fixture": "./src/fixture.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      },
      "./matchers": {
        "types": "./dist/matchers.d.mts",
        "import": "./dist/matchers.mjs"
      },
      "./fixture": {
        "types": "./dist/fixture.d.mts",
        "import": "./dist/fixture.mjs"
      }
    }
  },
  "tsdown": {
    "entry": [
      "src/index.ts",
      "src/matchers.ts",
      "src/fixture.ts"
    ],
    "format": "esm",
    "dts": true,
    "clean": true
  },
  "peerDependencies": {
    "@termless/core": "*",
    "vitest": ">=2.0.0"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=23.6.0"
  }
}
