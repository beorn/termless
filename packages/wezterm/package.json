{
  "name": "@termless/wezterm",
  "version": "0.4.0",
  "description": "WezTerm backend for termless — wezterm-term VT parser via napi-rs for cross-terminal TUI testing",
  "keywords": [
    "headless",
    "napi-rs",
    "rust",
    "sixel",
    "terminal",
    "terminal-emulator",
    "terminal-testing",
    "tui",
    "wezterm"
  ],
  "homepage": "https://termless.dev/",
  "bugs": {
    "url": "https://github.com/beorn/termless/issues"
  },
  "license": "MIT",
  "author": "Beorn",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/termless.git",
    "directory": "packages/wezterm"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "module": "./dist/index.mjs",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "build:native": "cd native && cargo build --release",
    "postbuild:native": "cp native/target/release/libtermless_wezterm_native.dylib termless-wezterm.node"
  },
  "peerDependencies": {
    "@termless/core": "*"
  },
  "tsdown": {
    "clean": true,
    "dts": true,
    "entry": "src/index.ts",
    "format": "esm"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=23.6.0"
  }
}
