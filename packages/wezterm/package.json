{
  "name": "@termless/wezterm",
  "version": "0.2.0",
  "description": "WezTerm backend for termless — wezterm-term VT parser via napi-rs",
  "homepage": "https://github.com/beorn/termless",
  "bugs": {
    "url": "https://github.com/beorn/termless/issues"
  },
  "license": "MIT",
  "author": "Beorn",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/termless.git",
    "directory": "packages/wezterm"
  },
  "files": [
    "src",
    "native",
    "*.node"
  ],
  "type": "module",
  "module": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
