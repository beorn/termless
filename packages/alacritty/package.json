{
  "name": "termless-alacritty",
  "version": "0.1.0",
  "description": "Alacritty backend for termless — alacritty_terminal via napi-rs",
  "license": "MIT",
  "author": "Beorn",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/termless",
    "directory": "packages/alacritty"
  },
  "homepage": "https://github.com/beorn/termless",
  "bugs": {
    "url": "https://github.com/beorn/termless/issues"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "module": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "peerDependencies": {
    "termless": "*"
  },
  "napi": {
    "binaryName": "termless-alacritty-native",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  }
}
