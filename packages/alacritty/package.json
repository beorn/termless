{
  "name": "@termless/alacritty",
  "version": "0.3.0",
  "description": "Alacritty backend for termless — alacritty_terminal via napi-rs for cross-terminal TUI testing",
  "keywords": [
    "alacritty",
    "headless",
    "napi-rs",
    "rust",
    "terminal",
    "terminal-emulator",
    "terminal-testing",
    "tui"
  ],
  "homepage": "https://termless.dev/",
  "bugs": {
    "url": "https://github.com/beorn/termless/issues"
  },
  "license": "MIT",
  "author": "Beorn",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/termless.git",
    "directory": "packages/alacritty"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "module": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  },
  "peerDependencies": {
    "@termless/core": "*"
  },
  "napi": {
    "binaryName": "termless-alacritty-native",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
