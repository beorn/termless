{
  "name": "@termless/peekaboo",
  "version": "0.3.1",
  "description": "Peekaboo backend for termless — OS-level terminal automation and testing via real terminal apps",
  "keywords": [
    "accessibility",
    "e2e-testing",
    "macos",
    "os-automation",
    "peekaboo",
    "screenshot",
    "terminal",
    "terminal-automation",
    "terminal-testing",
    "tui"
  ],
  "homepage": "https://termless.dev/",
  "bugs": {
    "url": "https://github.com/beorn/termless/issues"
  },
  "license": "MIT",
  "author": "Beorn",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/termless.git",
    "directory": "packages/peekaboo"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "module": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "dependencies": {
    "@xterm/headless": "^5.5.0"
  },
  "peerDependencies": {
    "@termless/core": "*",
    "@termless/xtermjs": "*"
  },
  "tsdown": {
    "clean": true,
    "dts": true,
    "entry": "src/index.ts",
    "format": "esm"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=23.6.0"
  }
}
